# OpenRouter — one key reaches GPT, Claude, Gemini, Llama, Grok, Kimi, etc.
OPENROUTER_API_KEY=

# HuggingFace Inference Endpoint — default GSA embedding backend.
# Deploy your embedder (e.g. intfloat/e5-mistral-7b-instruct) on HF
# Inference Endpoints, then paste the endpoint URL and a User Access Token.
HF_ENDPOINT_URL=
HF_TOKEN=
# Optional: label the deployed model for cache keying / logs.
# HF_EMBED_MODEL=intfloat/e5-mistral-7b-instruct

# NVIDIA NIM — alternative embedding backend (for catalog-available models).
# NVIDIA_API_KEY=
# NVIDIA_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2

# Optional direct LLM provider keys (only if bypassing OpenRouter)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# MOONSHOT_API_KEY=

# Optional: override the cost-tracking DB location
# STEREOTYPE_BENCH_DB_PATH=/custom/path/costs.sqlite
