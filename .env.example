# OpenRouter — one key reaches GPT, Claude, Gemini, Llama, Grok, Kimi, etc.
OPENROUTER_API_KEY=

# Optional direct provider keys (only needed if bypassing OpenRouter)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# MOONSHOT_API_KEY=

# NVIDIA NIM (for hosted llama-embed-nemotron-8b — used by gsa-core)
NVIDIA_API_KEY=

# Optional: override the cost-tracking DB location
# STEREOTYPE_BENCH_DB_PATH=/custom/path/costs.sqlite
